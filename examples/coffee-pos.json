{
  "format": "stadiae-v3",
  "interfaces": [
    {
      "name": "POS",
      "description": "Operator-facing commands from the touch terminal."
    },
    {
      "name": "Inventory",
      "description": "Stock-level notifications between the inventory tracker and the order manager."
    },
    {
      "name": "Payment",
      "description": "Payment authorization status updates."
    },
    {
      "name": "Service",
      "description": "Barista / kitchen workflow events."
    }
  ],
  "messages": [
    {
      "interface": "POS",
      "name": "StartOrder",
      "description": "Operator opens a new order at the till.",
      "parameters": [
        {
          "name": "operatorId",
          "type": "string"
        },
        {
          "name": "tableNumber",
          "type": "uint"
        }
      ]
    },
    {
      "interface": "POS",
      "name": "AddItem",
      "description": "Operator adds an item to the open order.",
      "parameters": [
        {
          "name": "itemId",
          "type": "string"
        },
        {
          "name": "quantity",
          "type": "uint"
        },
        {
          "name": "modifiers",
          "type": "string[]"
        }
      ]
    },
    {
      "interface": "POS",
      "name": "RemoveItem",
      "description": "Operator removes a line from the open order.",
      "parameters": [
        {
          "name": "lineId",
          "type": "string"
        }
      ]
    },
    {
      "interface": "POS",
      "name": "Submit",
      "description": "Operator finalises the order and moves to payment."
    },
    {
      "interface": "POS",
      "name": "Cancel",
      "description": "Operator abandons the order before payment."
    },
    {
      "interface": "Payment",
      "name": "Approved",
      "description": "Card reader confirms payment authorized.",
      "parameters": [
        {
          "name": "authCode",
          "type": "string"
        },
        {
          "name": "amount",
          "type": "uint"
        }
      ]
    },
    {
      "interface": "Payment",
      "name": "Declined",
      "description": "Card reader reports payment refused.",
      "parameters": [
        {
          "name": "reason",
          "type": "string"
        }
      ]
    },
    {
      "interface": "Inventory",
      "name": "StockOk",
      "description": "Requested items are all in stock.",
      "parameters": [
        {
          "name": "orderId",
          "type": "string"
        }
      ]
    },
    {
      "interface": "Inventory",
      "name": "StockLow",
      "description": "One or more requested items are low or out of stock.",
      "parameters": [
        {
          "name": "orderId",
          "type": "string"
        },
        {
          "name": "shortageItems",
          "type": "string[]"
        }
      ]
    },
    {
      "interface": "Inventory",
      "name": "Reserve",
      "description": "Reserve inventory for items on an order.",
      "parameters": [
        {
          "name": "orderId",
          "type": "string"
        },
        {
          "name": "items",
          "type": "string[]"
        }
      ]
    },
    {
      "interface": "Inventory",
      "name": "Release",
      "description": "Release previously-reserved inventory (cancellation path).",
      "parameters": [
        {
          "name": "orderId",
          "type": "string"
        }
      ]
    },
    {
      "interface": "Service",
      "name": "OrderReady",
      "description": "Kitchen signals the order is ready for pickup.",
      "parameters": [
        {
          "name": "orderId",
          "type": "string"
        }
      ]
    }
  ],
  "components": [
    {
      "name": "OrderManager",
      "arrowFontSize": 9,
      "stateFontSize": 12,
      "states": [
        {
          "name": "Idle",
          "description": "No order open. Waiting for the operator."
        },
        {
          "name": "Building",
          "description": "Order is open; operator can add/remove items."
        },
        {
          "name": "CheckingStock",
          "description": "Awaiting inventory response before submission."
        },
        {
          "name": "AwaitingPayment",
          "description": "Stock confirmed; waiting for card reader result."
        },
        {
          "name": "Preparing",
          "description": "Payment approved; order sent to kitchen."
        },
        {
          "name": "Completed",
          "description": "Order handed off to customer."
        }
      ],
      "choicePoints": [
        {
          "name": "HasItems",
          "question": "Does the order have any items?"
        }
      ],
      "transitions": [
        {
          "source": "START",
          "target": "Idle",
          "messages": []
        },
        {
          "source": "Idle",
          "target": "Building",
          "messages": [
            {
              "interface": "POS",
              "name": "StartOrder"
            }
          ]
        },
        {
          "source": "Building",
          "target": "Building",
          "messages": [
            {
              "interface": "POS",
              "name": "AddItem"
            }
          ]
        },
        {
          "source": "Building",
          "target": "Building",
          "messages": [
            {
              "interface": "POS",
              "name": "RemoveItem"
            }
          ]
        },
        {
          "source": "Building",
          "target": "Idle",
          "messages": [
            {
              "interface": "POS",
              "name": "Cancel"
            }
          ]
        },
        {
          "source": "Building",
          "target": "CP_HasItems",
          "messages": [
            {
              "interface": "POS",
              "name": "Submit"
            }
          ]
        },
        {
          "source": "CP_HasItems",
          "target": "Building",
          "messages": []
        },
        {
          "source": "CP_HasItems",
          "target": "CheckingStock",
          "messages": []
        },
        {
          "source": "CheckingStock",
          "target": "AwaitingPayment",
          "messages": [
            {
              "interface": "Inventory",
              "name": "StockOk"
            }
          ]
        },
        {
          "source": "CheckingStock",
          "target": "Building",
          "messages": [
            {
              "interface": "Inventory",
              "name": "StockLow"
            }
          ]
        },
        {
          "source": "AwaitingPayment",
          "target": "Preparing",
          "messages": [
            {
              "interface": "Payment",
              "name": "Approved"
            }
          ]
        },
        {
          "source": "AwaitingPayment",
          "target": "Building",
          "messages": [
            {
              "interface": "Payment",
              "name": "Declined"
            }
          ]
        },
        {
          "source": "Preparing",
          "target": "Completed",
          "messages": [
            {
              "interface": "Service",
              "name": "OrderReady"
            }
          ]
        },
        {
          "source": "Completed",
          "target": "Idle",
          "messages": [
            {
              "interface": "Timer",
              "name": "Timeout"
            }
          ]
        }
      ],
      "displayName": "Order Manager",
      "description": "Core component tracking an order from creation through payment and fulfilment. Holds the per-order state and delegates stock checks to the InventoryTracker, payment to the CardReader handler, and persistence to the Database handler.\nAll user-visible status text is pushed to the Display handler so the customer sees the same information the operator does."
    },
    {
      "name": "InventoryTracker",
      "arrowFontSize": 9,
      "stateFontSize": 12,
      "states": [
        {
          "name": "Ready",
          "description": "Normal operating state — serving stock queries."
        },
        {
          "name": "Reserving",
          "description": "Evaluating a reservation request and persisting the result."
        }
      ],
      "choicePoints": [
        {
          "name": "Available",
          "question": "All in\\nstock?",
          "description": "Check if all items are in stock."
        }
      ],
      "transitions": [
        {
          "source": "START",
          "target": "Ready",
          "messages": []
        },
        {
          "source": "Ready",
          "target": "Ready",
          "messages": [
            {
              "interface": "Inventory",
              "name": "Release"
            }
          ]
        },
        {
          "source": "Ready",
          "target": "CP_Available",
          "messages": [
            {
              "interface": "Inventory",
              "name": "Reserve"
            }
          ],
          "connector": "Left",
          "length": 1
        },
        {
          "source": "CP_Available",
          "target": "Reserving",
          "messages": [
            {
              "interface": "Logical",
              "name": "Yes"
            }
          ],
          "connector": "Down",
          "length": 1
        },
        {
          "source": "Reserving",
          "target": "Ready",
          "messages": [
            {
              "interface": "Inventory",
              "name": "Reserve"
            }
          ],
          "connector": "Up",
          "length": 1
        },
        {
          "source": "CP_Available",
          "target": "Ready",
          "messages": [
            {
              "interface": "Logical",
              "name": "No"
            }
          ],
          "connector": "Right",
          "length": 1
        }
      ],
      "displayName": "Inventory Tracker",
      "description": "Maintains per-item stock counts. Receives Reserve/Release messages from the OrderManager when orders are submitted or cancelled, and responds with StockOk or StockLow accordingly. Persists stock snapshots to the database on every reservation so crash recovery starts from the last known state."
    }
  ],
  "connections": [
    {
      "component": "OrderManager",
      "interface": "POS",
      "connector": "Down",
      "length": 1
    },
    {
      "component": "OrderManager",
      "interface": "Inventory",
      "connector": "Right",
      "length": 1
    },
    {
      "component": "OrderManager",
      "interface": "Payment",
      "connector": "Left",
      "length": 1
    },
    {
      "component": "OrderManager",
      "interface": "Service",
      "connector": "Down",
      "length": 2
    },
    {
      "component": "InventoryTracker",
      "interface": "Inventory",
      "connector": "Down",
      "length": 1
    }
  ],
